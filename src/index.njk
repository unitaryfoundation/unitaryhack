---
layout: base.njk
section: home
bodyClass: body--landing
mainClass: main--landing
hideSiteHeader: true
hideSiteDrawer: true
hideSiteFooter: true
---
<div class="home-page">
  {% include "partials/home-header.njk" %}

  <section class="landing-hero" aria-labelledby="landing-title">
    <div class="landing-hero__mark">
      {% include "partials/home-brand-mark.njk" %}
    </div>

    <div class="landing-hero__content">
      <h1 id="landing-title" class="landing-hero__title">
        <span class="landing-hero__title-line">{{ home.headline_regular }}</span>
        <span class="landing-hero__title-line landing-hero__title-line--accent">{{ home.headline_emphasis }}</span>
      </h1>
      <p class="landing-hero__subtitle">
        {% if home.subheadline_lines %}
          {% for line in home.subheadline_lines %}
            <span class="landing-hero__subtitle-line">{{ line }}</span>
          {% endfor %}
        {% else %}
          {{ home.subheadline }}
        {% endif %}
      </p>
    </div>
  </section>

  <section class="landing-panel" aria-label="unitaryHACK overview">
    <div class="landing-panel__copy">
      {% for paragraph in home.panel_copy %}
        {{ paragraph | withPathPrefix | markdown | safe }}
      {% endfor %}
    </div>

    <a class="landing-panel__cta" href="{{ home.panel_cta_url | url }}">
      {{ home.panel_cta_label }}
    </a>

    {% include "partials/home-supporters.njk" %}
  </section>

  {% include "partials/home-footer-note.njk" %}
</div>
