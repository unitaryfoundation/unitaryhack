<section class="drawer" id="drawer-name" data-drawer-target>
  <div class="drawer__overlay" data-drawer-close tabindex="-1"></div>
  <div class="drawer__wrapper">
    <div class="drawer__header">
      <a class="drawer__brand" href="{{ '/' | url }}" aria-label="unitaryHACK home">
        <span class="drawer__brand-letter">H</span>
        <span class="drawer__brand-glyph">&lt;\&gt;</span>
        <span class="drawer__brand-letter">K</span>
      </a>
      <button class="drawer__close" data-drawer-close aria-label="Close Drawer">
        {{ global.close_icon | svg | safe }}
      </button>
    </div>
    <div class="drawer__content">
      <ul class="drawer__nav">
      {%- for item in home.nav_items %}
        {% set itemUrl = item.url | url %}
        <li class="drawer__nav-item">
          <a
            href="{{ itemUrl }}"
            {% if itemUrl == page.url %} aria-current="page"{% endif %}
          >
            {{ item.label }}
          </a>
        </li>
      {%- endfor %}
      </ul>
    </div>
  </div>
</section>
