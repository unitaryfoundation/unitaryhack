{%- for project in collections.sortedProjects -%}
  {% set project_id = project.data.id or project.data.title | lower %}
  {% set metadata = gh[project_id] %}
  {% set project_bounties = project.data.bounties %}
  {% if metadata and metadata.bounties %}
    {% set project_bounties = metadata.bounties %}
  {% endif %}
  <section class="bounty-project" aria-labelledby="bounty-project-{{ project.fileSlug }}">
    <div class="bounty-project__header">
      <h2 class="bounty-project__title" id="bounty-project-{{ project.fileSlug }}">
        {% if project.data.emoji %}
          <span class="project-card__emoji" aria-hidden="true">{{ project.data.emoji }}</span>
        {% endif %}
        <a href="{{ project.url | url }}">{{ project.data.title }}</a>
      </h2>
      {% if metadata and metadata.amount_available > 0 %}
        <p class="bounty-project__meta"><b>${{ metadata.amount_available }}</b> up for grabs!</p>
      {% elif metadata and metadata.total_amount > 0 and metadata.amount_available == 0 %}
        <p class="bounty-project__meta">Completed</p>
      {% elif project_bounties and project_bounties.length %}
        <p class="bounty-project__meta"><b>${{ project_bounties | sumBountyValues }}</b> in bounties</p>
      {% else %}
        <p class="bounty-project__meta">Bounties coming soon</p>
      {% endif %}
    </div>
    {% if project_bounties and project_bounties.length %}
      <ul class="bounties bounty-list">
        {%- for bounty in project_bounties -%}
          {% set state = bounty | bountyState %}
          <li class="bounty-list__item bounty-list__item--{{ state }}">
            <a class="bounty-link bounty-{{ state }}" href="{{ bounty | bountyIssueUrl(project.data.project_url) | url }}">
              <span class="bounty-link__value">${{ bounty.value }}</span>
              <span class="bounty-link__title">{% mdRender %}{{ bounty | bountyIssueLabel(project.data.project_url) }}{% endmdRender %}</span>
              {% if state != "open" %}
                <span class="bounty-link__state">{{ state | capitalize }}</span>
              {% endif %}
            </a>
          </li>
        {%- endfor -%}
      </ul>
    {% endif %}
  </section>
{%- endfor -%}
