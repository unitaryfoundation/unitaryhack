---
layout: base.njk
section: project
---
<div class="page-container">
  <h1>
    {% if emoji %}
      <span class="project-card__emoji">{{ emoji }}</span>
    {% endif %}
     <a href={{ project_url }}>{{ title }}</a>
  </h1>

  {{ layoutContent | safe }}

  {% if office_hours and office_hours.length %}
    <section class="project-office-hours" aria-labelledby="project-office-hours-title">
      <h2 class="project-office-hours__title" id="project-office-hours-title">Office hours</h2>
      <ul class="project-office-hours__list">
        {% for slot in office_hours %}
          <li class="project-office-hours__item">
            <div class="project-office-hours__field">
              <span class="project-office-hours__label">Date</span>
              <span class="project-office-hours__value">{{ slot.date }}</span>
            </div>
            <div class="project-office-hours__field">
              <span class="project-office-hours__label">Time</span>
              <span class="project-office-hours__value project-office-hours__value--time">{{ slot.time }}</span>
            </div>
            <div class="project-office-hours__field">
              <span class="project-office-hours__label">Maintainer</span>
              <span class="project-office-hours__value">{{ slot.maintainer }}</span>
            </div>
          </li>
        {% endfor %}
      </ul>
    </section>
  {% endif %}

  <div class="hr"></div>


  {% set project_meta = gh[id or title | lower] %}
  {% set project_bounties = project_meta.bounties if project_meta and project_meta.bounties else bounties %}
  {% set closed_bounties = project_bounties | closedBounties %}
  {% if closed_bounties and closed_bounties.length %}
    <h5>Closed bounties:</h5>
    <ul class="bounties">
      {% for bounty in closed_bounties %}
        {% set comma = joiner(", ") %}
        <li>
          <a class="bounty-link bounty-closed" href="{{ bounty | bountyIssueUrl(project_url) | url }}">${{ bounty.value }} | {% mdRender %}{{ bounty | bountyIssueLabel(project_url) }}{% endmdRender %}</a>
          {% if bounty.assignees and bounty.assignees.length != 0 %}
            <br>
            closed by:
            {% for hacker in bounty.assignees -%}
              {{ comma() }}<a href="https://github.com/{{ hacker }}">{{ hacker }}</a>
            {%- endfor %}
          {% endif %}
        </li>
      {% endfor %}
    </ul>
  {% endif %}

  <nav>
    <a href="{{ '/projects/' | url }}">← View All Projects</a>
  </nav>
</div>
