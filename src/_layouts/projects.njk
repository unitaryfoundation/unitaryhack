---
layout: base.njk
section: projects
pagination:
  data: collections
  size: Infinity
  filter:
    - project
---
<div class="page-margin">
  <div class="project-container">

    <h1>{{title}}</h1>

    {% if subtitle %}
      <p>{{ subtitle }}</p>
    {% endif %}

    <div class="hr"></div>

  </div>

  {{ layoutContent | safe }}

  <section class="page-container">
    <p>Please check back soon for the 2026 participating projects.</p>
  </section>
</div>
